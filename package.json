{
	"name": "link-checker",
	"version": "0.1.3",
	"private": false,
	"description": "GitHub Action and CLI for checking markdown links.",
	"bin": {
		"link-checker": "./dist/cli.mjs"
	},
	"type": "module",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		}
	},
	"scripts": {
		"build": "tsdown",
		"check": "pnpm run lint && pnpm run typecheck && pnpm run test && pnpm run build",
		"dev:action": "tsx src/action.ts",
		"dev:cli": "tsx src/cli.ts",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"lint": "oxlint .",
		"lint:fix": "oxlint --fix .",
		"smoke": "tsx scripts/smoke.ts",
		"test:e2e": "vitest run --config vitest.e2e.config.ts",
		"test": "vitest run",
		"test:unit": "vitest run --config vitest.unit.config.ts",
		"test:watch": "vitest",
		"typecheck": "tsc --noEmit -p tsconfig.json"
	},
	"dependencies": {
		"@actions/core": "^3.0.0",
		"@commander-js/extra-typings": "^14.0.0",
		"commander": "^14.0.3",
		"globby": "^16.2.0",
		"jsonc-parser": "^3.3.1",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"remark-gfm": "^4.0.1",
		"remark-parse": "^11.0.0",
		"unified": "^11.0.5",
		"unist-util-visit": "^5.1.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"oxfmt": "^0.45.0",
		"oxlint": "^1.60.0",
		"tsdown": "^0.21.8",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.4"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "pnpm@11.1.3"
}
